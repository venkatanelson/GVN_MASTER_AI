//@version=5
indicator("GVN MASTER Indicator 2026 PRO", overlay=true)

// =====================
// TOGGLING TABLES
// =====================
showTable1 = input.bool(true, "Show 1st Entry Table", group="Table Settings")
showTable2 = input.bool(true, "Show 2nd Entry Table", group="Table Settings")
showTable3 = input.bool(true, "Show 3rd (Z to H) Entry Table", group="Table Settings")

// =====================
// LABELS SETTINGS (SL & GVN)
// =====================
showSLLabels = input.bool(true, "Show SL Labels", group="Labels Settings")
showGVNLabel = input.bool(true, "Show GVN POC Label", group="Labels Settings")

// =====================
// MAIN LINES SETTINGS (సింగిల్ టిక్ మార్క్)
// =====================
showMainLines = input.bool(true, "Main Market Only (1 Click Show All)", group="Main Lines Settings")
lineStyleInput = input.string("Solid", "Main Market Lines Style", options=["Solid", "Circles", "Cross", "Step Line"], group="Main Lines Settings")
mLineStyle = lineStyleInput == "Circles" ? plot.style_circles : lineStyleInput == "Cross" ? plot.style_cross : lineStyleInput == "Step Line" ? plot.style_stepline : plot.style_line

// 9:15 Base FIX
var float baseHigh = na
var float baseLow  = na

if (hour(time) == 9 and minute(time) == 15)
    baseHigh := high
    baseLow  := low

baseDiff = baseHigh - baseLow
baseMid  = baseDiff / 2

N1 = baseHigh + baseMid
N2 = baseLow  + baseMid

plot(showMainLines ? N1 : na, "Main Market 1", color=color.green, linewidth=2, style=mLineStyle)
plot(showMainLines ? N2 : na, "Main Market 2", color=color.rgb(231, 42, 42), linewidth=2, style=mLineStyle)

// =====================
// Center Level
// =====================
C1 = (N1 + N2) / 2
plot(showMainLines ? C1 : na, "Main Market 3", color=color.rgb(243, 121, 64), linewidth=1, style=mLineStyle)

// =====================
// GVN Levels
// =====================
gvn0   = N2 * 0.118 / 0.5
gvn100 = N1 * 0.786 / 0.5
gvnR   = gvn100 - gvn0

plot(gvn0,   title="Gvn=i0",   color=color.rgb(16,231,124), linewidth=1)
plot(gvn100, title="Gvn=i1",   color=color.aqua, linewidth=1)

i2 = gvn0 + 0.763 * gvnR
i3 = gvn0 + 0.618 * gvnR
i5 = gvn0 + 0.5   * gvnR
i6 = gvn0 + 0.382 * gvnR
i7 = gvn0 + 0.220 * gvnR

plot(i2, "Gvn=i2", color=color.red)
plot(i3, "Gvn=i3", color=color.rgb(231,43,168))
plot(i5, "Gvn=i5", color=color.rgb(11,46,201), linewidth=1)
plot(i6, "Gvn=i6", color=color.purple)
plot(i7, "Gvn=i7", color=color.black)

/// =====================
// BUY (Original Box + SL Label)
// =====================
buyEntry = i5
buyT1    = i3
buyT2    = i2
buySL    = buyEntry - 12

var bool buyActive = false

if ta.crossover(close, buyEntry)
    buyActive := true
    
    // Profit Zone
    box.new(bar_index, buyT2, bar_index+10, buyEntry, bgcolor=color.new(#b4ddb6,60), border_color=na, border_width=0)

    // Stoploss Zone
    box.new(bar_index, buyEntry, bar_index+10, buySL, bgcolor=color.new(#e656c6,60), border_color=na, border_width=0)
     
    if showSLLabels
        label.new(bar_index+5, buySL, "SL: " + str.tostring(buySL), color=color.new(#e656c6, 30), style=label.style_label_up, textcolor=color.white, size=size.small)

if buyActive and (close >= buyT2 or close <= buySL)
    buyActive := false

// =====================
// SELL (Original Box + SL Label)
// =====================
sellEntry = i7
sellT1    = i6
sellT2    = i5
sellSL    = sellEntry - 12

var bool sellActive = false

if ta.crossunder(close, sellEntry)
    sellActive := true
    
    // Profit Zone
    box.new(bar_index, sellEntry, bar_index+10, sellT2, bgcolor=color.new(#a1bba1, 80), border_color=na, border_width=0)

    // Stoploss Zone
    box.new(bar_index, sellSL, bar_index+10, sellEntry, bgcolor=color.new(#e656c6,80), border_color=na, border_width=0)

    if showSLLabels
        label.new(bar_index+5, sellSL, "SL: " + str.tostring(sellSL), color=color.new(#e656c6, 30), style=label.style_label_down, textcolor=color.white, size=size.small)

if sellActive and (close <= sellT2 or close >= sellSL)
    sellActive := false

// =====================
// 3rd ENTRY (GVN0) (Original Box + SL Label)
// =====================
thirdEntry = gvn0
thirdT1 = i7
thirdT2 = i6
thirdT3 = i5
thirdSL = thirdEntry - 12

var bool thirdActive = false

if ta.crossover(close, thirdEntry)
    thirdActive := true

    // Profit Zone
    box.new(bar_index, thirdT3, bar_index+10, thirdEntry, bgcolor=color.new(#b4ddb6, 80), border_color=na, border_width=0)

    // Stoploss Zone
    box.new(bar_index, thirdEntry, bar_index+10, thirdSL, bgcolor=color.new(#e656c6,80), border_color=na, border_width=0)

    if showSLLabels
        label.new(bar_index+5, thirdSL, "SL: " + str.tostring(thirdSL), color=color.new(#e656c6, 30), style=label.style_label_up, textcolor=color.white, size=size.small)

if thirdActive and (close >= thirdT3 or close <= thirdSL)
    thirdActive := false

// =====================
// FIXED RANGE VOLUME PROFILE POC
// =====================
vpLookback = input.int(100, "Fixed Range Volume Lookback", minval=10, group="Auto Volume Profile (POC)")
vpStep = input.float(5.0, "Volume Profile Price Step", minval=0.5, group="Auto Volume Profile (POC)")
showVP = input.bool(true, "Show Automatic POC Line", group="Auto Volume Profile (POC)")

var float pocLevel = na

if showVP and barstate.islast
    a_prices = array.new_float(0)
    a_vols   = array.new_float(0)
    
    for i = 0 to vpLookback - 1
        p = math.round(hlc3[i] / vpStep) * vpStep
        v = volume[i]
        
        idx = array.indexof(a_prices, p)
        if idx >= 0
            array.set(a_vols, idx, array.get(a_vols, idx) + v)
        else
            array.push(a_prices, p)
            array.push(a_vols, v)

    maxV = 0.0
    maxIdx = -1
    for i = 0 to array.size(a_vols) - 1
        if array.get(a_vols, i) > maxV
            maxV := array.get(a_vols, i)
            maxIdx := i
            
    pocLevel := maxIdx >= 0 ? array.get(a_prices, maxIdx) : na

var line pocLine = na
var label pocLabel = na
if showVP and barstate.islast and not na(pocLevel)
    line.delete(pocLine)
    label.delete(pocLabel)
    
    pocLine := line.new(bar_index - 15, pocLevel, bar_index + 10, pocLevel, color=color.rgb(255, 153, 0), width=3, style=line.style_solid)
    if showGVNLabel
        pocLabel := label.new(bar_index + 10, pocLevel, "GVN: " + str.tostring(pocLevel), color=color.rgb(255, 153, 0), textcolor=color.black, style=label.style_label_left, size=size.small)

// =====================
// VWAP & Trend Lines
// =====================
plot(ta.vwap, color=color.rgb(137, 35, 233), title="VWAP")

hcl3 = hlc3
hcl3_52 = ta.sma(hcl3, 52)
plot(hcl3_52, color=color.red, title="Hcl")

pivotCandle = (high[1] + low[1] + close[1]) / 3
touchedCandle = high >= pivotCandle and low <= pivotCandle
colorCandle = touchedCandle ? color.rgb(255, 253, 231, 100) : color.rgb(44, 42, 10)
plot(pivotCandle, title="cp", color=colorCandle, linewidth=1)

openLowCandle = (open == low)
openHighCandle = (open == high)
barcolor(openLowCandle ? color.black : openHighCandle ? color.purple : na)

// =====================
// Supertrend + EMA
// =====================
atrPeriod = input.int(7, "ATR Length", minval=1)
factor = input.float(0.90, "Factor", minval=0.08, step=0.01)
emaShortPeriod = input.int(5, "EMA 5", minval=1)
emaLongPeriod = input.int(10, "EMA 10", minval=1)

[supertrend, direction] = ta.supertrend(factor, atrPeriod)

emaShort = ta.ema(close, emaShortPeriod)
emaLong  = ta.ema(close, emaLongPeriod)

buySignal  = ta.crossover(close, supertrend)
sellSignal = ta.crossunder(close, supertrend)

plotshape(buySignal, title="Buy Signal", location=location.belowbar, color=color.rgb(163, 211, 151), style=shape.labelup, text="buy", textcolor=color.rgb(10, 10, 10), size=size.tiny)
plotshape(sellSignal, title="Sell Signal", location=location.abovebar, color=color.rgb(216, 109, 211), style=shape.labeldown, text="sell", textcolor=color.rgb(27, 25, 25), size=size.tiny)

alertcondition(buySignal, title="Buy Alert", message="Supertrend Buy Signal")
alertcondition(sellSignal, title="Sell Alert", message="Supertrend Sell Signal")

// =====================
// TABLE POSITION SETTINGS
// =====================
firstPosInput  = input.string("Middle Left",  "1st Entry Table Position", options=["Top Left","Middle Left","Bottom Left","Top Center","Middle Center","Bottom Center"], group="Table Settings")
secondPosInput = input.string("Top Center",   "2nd Entry Table Position", options=["Top Center","Middle Center","Bottom Center","Top Right","Middle Right","Bottom Right"], group="Table Settings")
thirdPosInput  = input.string("Bottom Center","3rd Entry Table Position", options=["Top Center","Middle Center","Bottom Center","Top Right","Middle Right","Bottom Right"], group="Table Settings")

posConvert(pos)=>
     pos=="Top Left"?position.top_left:
     pos=="Middle Left"?position.middle_left:
     pos=="Bottom Left"?position.bottom_left:
     pos=="Top Center"?position.top_center:
     pos=="Middle Center"?position.middle_center:
     pos=="Bottom Center"?position.bottom_center:
     pos=="Top Right"?position.top_right:
     pos=="Middle Right"?position.middle_right:
     position.bottom_right

firstTablePos  = posConvert(firstPosInput)
secondTablePos = posConvert(secondPosInput)
thirdTablePos  = posConvert(thirdPosInput)

tableFont = input.string("tiny", "Table Font Size", options = ["tiny","small","normal","large"], group="Table Settings")
fontSize = tableFont == "tiny" ? size.tiny : tableFont == "small" ? size.small : tableFont == "normal" ? size.normal : size.large

// =====================
// TABLES GENERATION (LIVE DYNAMIC BOXES)
// =====================

// ----- 1st ENTRY TABLE -----
var table table1 = na
if showTable1 and na(table1)
    table1 := table.new(firstTablePos, 2, 3, border_width=1, border_color=color.black, frame_color=color.black, frame_width=1)

if showTable1 and barstate.islast
    color t1_bg  = buyActive ? color.rgb(163, 211, 151) : color.rgb(30, 30, 30) 
    color t1_txt = buyActive ? color.black : color.rgb(200, 200, 200)
    
    table.cell(table1, 0, 0, "1st Entry 📈", bgcolor=buyActive ? color.black : color.rgb(15,15,15), text_color=buyActive ? color.rgb(163, 211, 151) : color.white, text_size=fontSize)
    table.cell(table1, 0, 1, "Target 1", bgcolor=t1_bg, text_color=t1_txt, text_size=fontSize)
    table.cell(table1, 0, 2, "Target 2", bgcolor=t1_bg, text_color=t1_txt, text_size=fontSize)

    table.cell(table1, 1, 0, str.tostring(buyEntry), bgcolor=t1_bg, text_color=t1_txt, text_size=fontSize)
    table.cell(table1, 1, 1, str.tostring(buyT1),    bgcolor=t1_bg, text_color=t1_txt, text_size=fontSize)
    table.cell(table1, 1, 2, str.tostring(buyT2),    bgcolor=t1_bg, text_color=t1_txt, text_size=fontSize)

// ----- 2nd ENTRY TABLE -----
var table table2 = na
if showTable2 and na(table2)
    table2 := table.new(secondTablePos, 2, 3, border_width=1, border_color=color.black, frame_color=color.black, frame_width=1)

if showTable2 and barstate.islast
    color t2_bg  = sellActive ? color.rgb(226, 144, 144) : color.rgb(30, 30, 30) 
    color t2_txt = sellActive ? color.black : color.rgb(200, 200, 200)

    table.cell(table2, 0, 0, "2nd Entry 📉", bgcolor=sellActive ? color.black : color.rgb(15,15,15), text_color=sellActive ? color.rgb(226, 144, 144) : color.white, text_size=fontSize)
    table.cell(table2, 0, 1, "Target 1", bgcolor=t2_bg, text_color=t2_txt, text_size=fontSize)
    table.cell(table2, 0, 2, "Target 2", bgcolor=t2_bg, text_color=t2_txt, text_size=fontSize)

    table.cell(table2, 1, 0, str.tostring(sellEntry), bgcolor=t2_bg, text_color=t2_txt, text_size=fontSize)
    table.cell(table2, 1, 1, str.tostring(sellT1),    bgcolor=t2_bg, text_color=t2_txt, text_size=fontSize)
    table.cell(table2, 1, 2, str.tostring(sellT2),    bgcolor=t2_bg, text_color=t2_txt, text_size=fontSize)

// ----- 3rd ENTRY TABLE (Z to H) -----
var table table3 = na
if showTable3 and na(table3)
    table3 := table.new(thirdTablePos, 2, 4, border_width=1, border_color=color.black, frame_color=color.black, frame_width=1)

if showTable3 and barstate.islast
    color t3_bg  = thirdActive ? color.rgb(33, 150, 243) : color.rgb(30, 30, 30) 
    color t3_txt = thirdActive ? color.white : color.rgb(200, 200, 200)

    table.cell(table3, 0, 0, "Z to H 🚀", bgcolor=thirdActive ? color.black : color.rgb(15,15,15), text_color=thirdActive ? color.rgb(33, 150, 243) : color.white, text_size=fontSize)
    table.cell(table3, 0, 1, "Target 1", bgcolor=t3_bg, text_color=t3_txt, text_size=fontSize)
    table.cell(table3, 0, 2, "Target 2", bgcolor=t3_bg, text_color=t3_txt, text_size=fontSize)
    table.cell(table3, 0, 3, "Target 3", bgcolor=t3_bg, text_color=t3_txt, text_size=fontSize)

    table.cell(table3, 1, 0, str.tostring(thirdEntry), bgcolor=t3_bg, text_color=t3_txt, text_size=fontSize)
    table.cell(table3, 1, 1, str.tostring(thirdT1),    bgcolor=t3_bg, text_color=t3_txt, text_size=fontSize)
    table.cell(table3, 1, 2, str.tostring(thirdT2),    bgcolor=t3_bg, text_color=t3_txt, text_size=fontSize)
    table.cell(table3, 1, 3, str.tostring(thirdT3),    bgcolor=t3_bg, text_color=t3_txt, text_size=fontSize)

// =====================
// 80% Previous Day's Levels
// =====================
show80Lines = input.bool(true, 'Show 80% Previous Day Levels', group='80% Levels')
prevHigh = ta.highest(high, 1)[1]
prevLow = ta.lowest(low, 1)[1]
range80 = (prevHigh - prevLow) * 0.8
upperLevel = prevLow + range80
lowerLevel = prevHigh - range80

if show80Lines
    var line upperLine = na
    var line lowerLine = na
    line.delete(upperLine)
    line.delete(lowerLine)
    upperLine := line.new(x1=bar_index, y1=upperLevel, x2=bar_index + 500, y2=upperLevel, width=1, color=color.rgb(131, 196, 134), style=line.style_dashed)
    lowerLine := line.new(x1=bar_index, y1=lowerLevel, x2=bar_index + 500, y2=lowerLevel, width=1, color=color.rgb(226, 144, 144), style=line.style_dashed)

float GVNS = ta.valuewhen(ta.highestbars(volume, 50) == 0, close,0)
plot(GVNS, title="GVNS Level", color=color.new(color.black, 0), linewidth=2)

// ==========================================
// GVN AI SMART DASHBOARD (Volume, Time Zone, Inst & Flow)
// ==========================================
showAI = input.bool(true, "Show AI Sentiment Dashboard", group="AI Dashboard Settings")
aiBoxPos = input.string("Middle Right", "AI Dashboard Position", options=["Top Right", "Middle Right", "Bottom Right", "Top Center", "Bottom Center"], group="AI Dashboard Settings")
aiFontInput = input.string("tiny", "AI Dashboard Font Size", options=["tiny", "small", "normal", "large"], group="AI Dashboard Settings")

aiFontSize = aiFontInput == "tiny" ? size.tiny : aiFontInput == "small" ? size.small : aiFontInput == "normal" ? size.normal : size.large

aiPosConvert(p) =>
    p == "Top Right" ? position.top_right :
     p == "Middle Right" ? position.middle_right :
     p == "Bottom Right" ? position.bottom_right :
     p == "Top Center" ? position.top_center :
     position.bottom_center

// 1. Calculate Volume Buying/Selling Pressure
aiLookback = input.int(20, "AI Volume Lookback", group="AI Dashboard Settings")
buyingVolume = math.sum(close > open ? volume : 0, aiLookback)
sellingVolume = math.sum(close < open ? volume : 0, aiLookback)

volRatio = buyingVolume / (sellingVolume == 0 ? 1 : sellingVolume)

// 2. Trend Confirmation (Using VWAP & 52 HLC3)
isPriceAboveVWAP = close > ta.vwap
isPriceAboveHLC = close > hcl3_52

// 3. AI Mode Decision
string aiMode = "SIDEWAYS"
color aiColor = color.yellow

if volRatio > 1.2 and isPriceAboveVWAP and isPriceAboveHLC
    aiMode := "BULLISH 🟢"
    aiColor := color.rgb(163, 211, 151)
else if volRatio < 0.8 and not isPriceAboveVWAP and not isPriceAboveHLC
    aiMode := "BEARISH 🔴"
    aiColor := color.rgb(226, 144, 144)

// 4. Time Zone Momentum Prediction (Indian Standard Time)
tHour = hour(time, "Asia/Kolkata")
tMin = minute(time, "Asia/Kolkata")
float timeVal = tHour + (tMin / 60.0)

string timeZoneStatus = "DULL ZONE (Wait ⚠️)"
color tzColor = color.rgb(120, 123, 134)

if (timeVal >= 9.25 and timeVal <= 10.5) 
    timeZoneStatus := "HIGH MOMENTUM ⚡ (Morning)"
    tzColor := color.rgb(255, 153, 0)
else if (timeVal >= 13.5 and timeVal <= 15.0) 
    timeZoneStatus := "HIGH MOMENTUM 🚀 (Breakout)"
    tzColor := color.rgb(33, 150, 243)

// 5. Volume Anomaly (Institutional Absorption)
avgV = ta.sma(volume, 20)
cBody = math.abs(close - open)
avgB = ta.sma(cBody, 20)
bool isInstPump = volume > (avgV * 2.5) and cBody <= avgB

string instText = isInstPump ? "🚨 BIG BOYS ACTIVE" : "📊 Normal Volume"
color instColor = isInstPump ? color.aqua : color.rgb(230,230,230)

// 6. SMART MONEY FLOW (Buyers / Sellers Control Delta)
buyVolFlow = (close >= open) ? volume : 0
sellVolFlow = (close < open) ? volume : 0
deltaFlow = buyVolFlow - sellVolFlow
avgDelta = ta.sma(deltaFlow, 10) 

string flowText = avgDelta > 0 ? "BUYERS CONTROL 🟢" : "SELLERS CONTROL 🔴"
color flowColor = avgDelta > 0 ? color.rgb(163, 211, 151) : color.rgb(226, 144, 144)

// ==========================================
// MTF SUPERTREND CONFIRMATION (5m, 15m, 60m)
// ==========================================
get_st_dir(f, p) =>
    [_, dir] = ta.supertrend(f, p)
    dir

dir5  = request.security(syminfo.tickerid, "5", get_st_dir(factor, atrPeriod))
dir15 = request.security(syminfo.tickerid, "15", get_st_dir(factor, atrPeriod))
dir60 = request.security(syminfo.tickerid, "60", get_st_dir(factor, atrPeriod))

dot5  = dir5 < 0 ? "🟢" : "🔴"
dot15 = dir15 < 0 ? "🟢" : "🔴"
dot60 = dir60 < 0 ? "🟢" : "🔴"
mtfDots = "  " + dot5 + dot15 + dot60

// 7. Draw the AI Table
var table aiTable = na
if showAI
    aiTable := table.new(aiPosConvert(aiBoxPos), 1, 5, border_width=2, border_color=color.black, frame_color=color.black, frame_width=2)

if showAI and barstate.islast
    table.cell(aiTable, 0, 0, "🤖 GVN AI ANALYSIS" + mtfDots, bgcolor=color.black, text_color=color.white, text_size=aiFontSize)
    table.cell(aiTable, 0, 1, "Mode: " + aiMode + "\nVol Ratio: " + str.tostring(volRatio, "#.##"), bgcolor=aiColor, text_color=color.black, text_size=aiFontSize, text_halign=text.align_left)
    table.cell(aiTable, 0, 2, "Zone: " + timeZoneStatus, bgcolor=tzColor, text_color=color.white, text_size=aiFontSize, text_halign=text.align_left)
    table.cell(aiTable, 0, 3, "Inst: " + instText, bgcolor=instColor, text_color=color.black, text_size=aiFontSize, text_halign=text.align_left)
    table.cell(aiTable, 0, 4, "Flow: " + flowText, bgcolor=flowColor, text_color=color.black, text_size=aiFontSize, text_halign=text.align_left)

// =====================
// LIQUIDITY SWEEP (STOP HUNT) - ఎమోజీలు
// =====================
lookback = 10
swingHigh = ta.highest(high, lookback)[1]
swingLow = ta.lowest(low, lookback)[1]
bullishSweep = low < swingLow and close > swingLow and close > open
bearishSweep = high > swingHigh and close < swingHigh and close < open

plotshape(bullishSweep, title="Bullish Sweep / Stop Hunt", location=location.belowbar, color=color.new(#17a421, 0), style=shape.labelup, text="🧹 Hunt", textcolor=color.black, size=size.tiny)
plotshape(bearishSweep, title="Bearish Sweep / Stop Hunt", location=location.abovebar, color=color.new(#d52528, 0), style=shape.labeldown, text="🧹 Hunt", textcolor=color.white, size=size.tiny)

// ==========================================
// PERFECT ALGO ENTRY CONFIRMATIONS (PRO)
// ==========================================
// 1. Previous Candle High/Low Break (Micro Breakout)
buyPrevHighBreak = close > high[1]
sellPrevLowBreak = close < low[1]

// 2. Volume Anomaly (1.5x average)
volSpike = volume > ta.sma(volume, 20) * 1.5

// 3. AI Mode / Control Affirmation
aiBullishStrong = (volRatio > 1.0) or (avgDelta > 0)
aiBearishStrong = (volRatio < 1.0) or (avgDelta < 0)

// 4. Touch Zones (Price touched the Entry Levels within perfectly short window)
// GVN i5 is Buy Level, GVN i7 is Sell Level. 
touchedi5 = ta.barssince(low <= i5 and close >= i5) <= 3
touchedi7 = ta.barssince(high >= i7 and close <= i7) <= 3

// 5. Final Strict Conditions for Algo
strictBuyAlgo = touchedi5 and buyPrevHighBreak and volSpike and aiBullishStrong
strictSellAlgo = touchedi7 and sellPrevLowBreak and volSpike and aiBearishStrong

// Plotting the Perfect Entry Signals for Algo
plotshape(strictBuyAlgo, title="Algo Perfect Buy", location=location.belowbar, color=color.new(color.lime, 0), style=shape.triangleup, text="🚀 ALGO", textcolor=color.black, size=size.small)
plotshape(strictSellAlgo, title="Algo Perfect Sell", location=location.abovebar, color=color.new(color.red, 0), style=shape.triangledown, text="🩸 ALGO", textcolor=color.white, size=size.small)

// Configured Alerts
alertcondition(strictBuyAlgo, title="GVN Perfect Buy (ALGO)", message="Perfect ALGO Buy Signal Triggered!")
alertcondition(strictSellAlgo, title="GVN Perfect Sell (ALGO)", message="Perfect ALGO Sell Signal Triggered!")
