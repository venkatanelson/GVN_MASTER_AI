//@version=5
indicator("GVN Master Algo", overlay=true)

// ==== User Inputs for Algo ====
stratMode = input.string("Strategy 1", title="Select Strategy Mode", options=["Strategy 1", "Strategy 2", "Strategy 3"])
lotSize = input.int(65, title="Lot Size (e.g., 65 for Nifty)", minval=1)
noOfLots = input.int(1, title="Number of Lots to Trade", minval=1)
gvn_secret = input.string("ANWZ22747T", title="GVN Dhan Secret Key")

finalQty = lotSize * noOfLots

// ==== Step 1: Detect New Day and 9:15 Candle ====
isNewDay = ta.change(time("D"))
is915Candle = (hour == 9 and minute == 15)

var float high915 = na
var float low915 = na
var float close915 = na
var float n1 = na
var float n2 = na

if isNewDay
    high915 := na
    low915 := na
    close915 := na
    n1 := na 
    n2 := na

if is915Candle
    high915 := high
    low915 := low
    close915 := close

valid = not na(high915) and not na(low915)
diff = valid ? (high915 - low915) : na
result = diff / 2

if valid
    n1 := high915 + result
    n2 := low915 + result

c1 = (n1 + n2) / 2

eLevel = n2 - math.floor(n2 * 3.2 / 1000)
tLevel = n2 + math.floor(n2 * 7.1 / 1000)

plot(n1, title="N1", color=color.green, linewidth=2)
plot(n2, title="N2", color=color.red, linewidth=2)
plot(c1, title="C1", color=color.orange, linewidth=2)
plot(eLevel, title="E Level", color=color.teal, linewidth=1)
plot(tLevel, title="T Level", color=color.fuchsia, linewidth=1)

gvn0_calculated_value = n2 * 0.118 / 0.5
gvn_i1_calculated_value = n1 * 0.786 / 0.5

gvn_i0_level = gvn_i1_calculated_value 
gvn_i1_level = gvn0_calculated_value  

gvn_i2 = gvn0_calculated_value + 0.763 * (gvn_i1_calculated_value - gvn0_calculated_value) 
gvn_i3 = gvn0_calculated_value + 0.618 * (gvn_i1_calculated_value - gvn0_calculated_value)
gvn_i5 = gvn0_calculated_value + 0.5 * (gvn_i1_calculated_value - gvn0_calculated_value)
gvn_i6 = gvn0_calculated_value + 0.382 * (gvn_i1_calculated_value - gvn0_calculated_value)
gvn_i7 = gvn0_calculated_value + 0.220 * (gvn_i1_calculated_value - gvn0_calculated_value)

plot(gvn_i0_level, title="GVN=i0", color=color.green) 
plot(gvn_i1_level, title="GVN=i1", color=color.green) 
plot(gvn_i2, title="GVN=i2", color=color.red, linewidth=2)
plot(gvn_i3, title="GVN=i3", color=color.gray)
plot(gvn_i5, title="GVN=i5", color=color.blue, linewidth=2)
plot(gvn_i6, title="GVN=i6", color=color.purple)
plot(gvn_i7, title="GVN=i7", color=color.black)

sl_i0 = gvn_i0_level - 12 
sl_i1 = gvn_i1_level - 12 
sl_i2 = gvn_i2 - 12
sl_i3 = gvn_i3 - 12
sl_i5 = gvn_i5 - 12
sl_i6 = gvn_i6 - 12
sl_i7 = gvn_i7 - 12

// Strategy 3 Dynamic Targets
dynTarget_i1 = (stratMode == "Strategy 3") ? gvn_i5 : gvn_i7
dynTarget_i5 = (stratMode == "Strategy 3") ? gvn_i2 : gvn_i3
dynTarget_i7 = (stratMode == "Strategy 3") ? gvn_i5 : gvn_i6

plot(sl_i0, title="SL i0", color=color.red)
plot(sl_i1, title="SL i1", color=color.red)
plot(sl_i2, title="SL i2", color=color.red)
plot(sl_i3, title="SL i3", color=color.red)
plot(sl_i5, title="SL i5", color=color.red)
plot(sl_i6, title="SL i6", color=color.red)
plot(sl_i7, title="SL i7", color=color.red)

t_i0 = gvn_i0_level - 2 
t_i2 = gvn_i2 - 2

float entryBuffer = 1.0     
float exitBuffer = 0.5      

buffered_gvn_i0_buy_entry_price = gvn_i0_level + entryBuffer 
buffered_gvn_i1_buy_entry_price = gvn_i1_level + entryBuffer 
buffered_gvn_i2_buy_entry_price = gvn_i2 + entryBuffer
buffered_gvn_i3_buy_entry_price = gvn_i3 + entryBuffer
buffered_gvn_i5_buy_entry_price = gvn_i5 + entryBuffer
buffered_gvn_i6_buy_entry_price = gvn_i6 + entryBuffer
buffered_gvn_i7_buy_entry_price = gvn_i7 + entryBuffer

buffered_sl_i0_long_exit_price = sl_i0 - exitBuffer 
buffered_sl_i1_long_exit_price = sl_i1 - exitBuffer 
buffered_sl_i2_long_exit_price = sl_i2 - exitBuffer
buffered_sl_i3_long_exit_price = sl_i3 - exitBuffer
buffered_sl_i5_long_exit_price = sl_i5 - exitBuffer
buffered_sl_i6_long_exit_price = sl_i6 - exitBuffer
buffered_sl_i7_long_exit_price = sl_i7 - exitBuffer

buffered_t_i0_long_exit_price = t_i0 + exitBuffer 
buffered_t_i2_long_exit_price = t_i0 + exitBuffer 

var bool tradeActive_i0 = false
var bool tradeActive_i1 = false 
var bool tradeActive_i2 = false
var bool tradeActive_i3 = false
var bool tradeActive_i5 = false
var bool tradeActive_i6 = false
var bool tradeActive_i7 = false

if isNewDay
    tradeActive_i0 := false
    tradeActive_i1 := false 
    tradeActive_i2 := false
    tradeActive_i3 := false
    tradeActive_i5 := false
    tradeActive_i6 := false
    tradeActive_i7 := false

// ==========================================
// ⚡ OPPOSITE STRIKE CORRELATION SYNC (CALL vs PUT) ⚡
// ==========================================
enableOppSync = input.bool(true, "Enable Opposite Strike Sync", group="Ultra Advanced Filters")
oppSymbol = input.symbol("", "Opposite Option Strike (e.g., NIFTY...PE)", group="Ultra Advanced Filters")

get_opp_base() =>
    var float oH = na
    var float oL = na
    if hour(time) == 9 and minute(time) == 15
        oH := high
        oL := low
    [oH, oL, close]

[oppBaseH, oppBaseL, oppCloseLocal] = request.security(oppSymbol, timeframe.period, get_opp_base(), ignore_invalid_symbol=true)

// Calculate Opposite GVN Levels
oppGvn0 = (oppBaseL + (oppBaseH - oppBaseL)/2) * 0.118 / 0.5
oppGvn100 = (oppBaseH + (oppBaseH - oppBaseL)/2) * 0.786 / 0.5
oppGvnR = oppGvn100 - oppGvn0
opp_i7 = oppGvn0 + 0.220 * oppGvnR
opp_i5 = oppGvn0 + 0.5 * oppGvnR
opp_i3 = oppGvn0 + 0.618 * oppGvnR

// Distance from Nearest Support
oppDistToFloor = math.min(math.abs(oppCloseLocal - opp_i7), math.abs(oppCloseLocal - opp_i5), math.abs(oppCloseLocal - opp_i3))
oppCandleSizeAvg = ta.sma(high - low, 10)
oppRoomInCandles = (oppCandleSizeAvg > 0) ? (oppDistToFloor / oppCandleSizeAvg) : 2.0

// Minimum 2 candles distance constraint
oppIsFarFromSupport = enableOppSync and not na(oppCloseLocal) ? (oppRoomInCandles >= 2.0) : true

// ==========================================
// 🎈 MAGNETIC WICK REJECTION & PRESSURE GAUGE
// ==========================================
candleTotalLen = high - low
lowerWickP = candleTotalLen > 0 ? (math.abs(math.min(open, close) - low) / candleTotalLen) * 100 : 0
upperWickP = candleTotalLen > 0 ? (math.abs(high - math.max(open, close)) / candleTotalLen) * 100 : 0

isRejectingSupport = lowerWickP > 50
isRejectingResistance = upperWickP > 50

// ==========================================
// 🛡️ LONG CANDLE VALIDATION (Fakeout Filter)
// ==========================================
avgCandleSize = ta.sma(candleTotalLen, 20)
isAbnormallyHuge = candleTotalLen > (avgCandleSize * 2.5)
validBreakoutBuy = not isAbnormallyHuge or (close > high - (candleTotalLen * 0.25)) // Proper close near high

// ==========================================
// 🧠 INTERNAL MARKET MEMORY & OBSERVATION 🧠
// ==========================================
// Translating user's request: "Create an observation coding inside, reset daily.
// It remembers state but doesn't plot messy stuff on the screen. Tracks trend & reversals."

var float sumVolumeInternal = 0.0
var float sumPriceVolInternal = 0.0
var int memoryTrendScore = 0
var int decayMemory = 0 // Tracks Theta Decay / Choppy Market

if isNewDay
    sumVolumeInternal := 0.0
    sumPriceVolInternal := 0.0
    memoryTrendScore := 0
    decayMemory := 0

sumVolumeInternal += volume
sumPriceVolInternal += (close * volume)

// 1. Average Point Level (Internal Flow VWAP)
avgPointLevel = sumVolumeInternal > 0 ? (sumPriceVolInternal / sumVolumeInternal) : close

// 2. Trend Memory
memoryTrendScore := close > avgPointLevel ? memoryTrendScore + 1 : memoryTrendScore - 1

// 3. Opposite Strike Synchronization Memory (Comparing Main vs Opp over time)
// If Main goes down AND Opp goes down = Theta Decay (Option Sellers eating premiums)
if not na(oppCloseLocal)
    if (close < close[1]) and (oppCloseLocal < oppCloseLocal[1])
        decayMemory += 1 
    else if (close > close[1]) or (oppCloseLocal > oppCloseLocal[1])
        decayMemory := math.max(0, decayMemory - 1)

// 4. Reversal Point Estimation internally
atr14 = ta.atr(14)
reversalPointUpper = avgPointLevel + (atr14 * 2.5) // Expected resistance
reversalPointLower = avgPointLevel - (atr14 * 2.5) // Expected bounce support

// Decision from Memory: Are we in a messy decaying/fakeout market zone?
isMarketDecaying = decayMemory > 4 


// ==========================================
// 📊 OBSERVATION MEMORY DASHBOARD (Subtle)
// ==========================================
showMemoryGauge = input.bool(true, title="Show Market State Dashboard", group="Ultra Advanced Filters")
if showMemoryGauge and barstate.islast
    var table memTable = table.new(position.bottom_right, 2, 4, border_width=1, border_color=color.rgb(50, 50, 50))
    
    // Status Logic
    statusColor = isMarketDecaying ? color.rgb(180, 180, 180) : (memoryTrendScore > 0 ? color.rgb(0, 200, 100) : color.rgb(220, 50, 50))
    statusText = isMarketDecaying ? "CHOPPY / DECAY" : (memoryTrendScore > 0 ? "BULLISH TREND" : "BEARISH WEAKNESS")
    
    table.cell(memTable, 0, 0, "GVN Market Memory", text_color=color.white, bgcolor=color.black, text_size=size.small)
    table.cell(memTable, 1, 0, statusText, text_color=color.black, bgcolor=statusColor, text_size=size.small)
    
    table.cell(memTable, 0, 1, "VW Average Point", text_color=color.silver, bgcolor=color.black, text_size=size.small)
    table.cell(memTable, 1, 1, str.tostring(math.round(avgPointLevel, 2)), text_color=color.white, bgcolor=color.black, text_size=size.small)
    
    table.cell(memTable, 0, 2, "Reversal Danger Area", text_color=color.silver, bgcolor=color.black, text_size=size.small)
    table.cell(memTable, 1, 2, str.tostring(math.round(reversalPointUpper, 2)), text_color=color.red, bgcolor=color.black, text_size=size.small)
    
    table.cell(memTable, 0, 3, "Bounce Area", text_color=color.silver, bgcolor=color.black, text_size=size.small)
    table.cell(memTable, 1, 3, str.tostring(math.round(reversalPointLower, 2)), text_color=color.green, bgcolor=color.black, text_size=size.small)


// ==========================================
// 🎯 TARGET LOCKOUT (safeFromFakeout)
// ==========================================
// Prevent taking another trade if one is ALREADY ACTIVE (Wait for Target/SL Hit)
safeFromFakeout = not tradeActive_i0 and not tradeActive_i1 and not tradeActive_i2 and not tradeActive_i3 and not tradeActive_i5 and not tradeActive_i6 and not tradeActive_i7

// ==========================================
// PERFECT ALGO ENTRY CONFIRMATIONS (PRO)
// ==========================================
// 1. Micro-Breakout: Previous Candle High Break
buyPrevHighBreak = close > high[1]

// 2. Volume Anomaly (1.5x of moving average)
volSMA = ta.sma(volume, 20)
volSpike = volSMA > 0 and (volume > volSMA * 1.5)

// The combined Perfect Entry condition (Added "not isMarketDecaying" from Memory module)
perfectEntryConf = buyPrevHighBreak and volSpike and oppIsFarFromSupport and validBreakoutBuy and safeFromFakeout and not isMarketDecaying

// ==========================================

// USING ta.crossover for BUYS and ta.crossunder for SL to prevent whipsaws
// ADDED perfectEntryConf TO BUY CONDITIONS
buyCondition_i0 = valid and ta.crossover(close, buffered_gvn_i0_buy_entry_price) and perfectEntryConf and not tradeActive_i0
slCondition_i0 = tradeActive_i0 and ta.crossunder(close, buffered_sl_i0_long_exit_price)
targetCondition_i0 = tradeActive_i0 and ta.crossover(close, buffered_t_i0_long_exit_price)

buyCondition_i1 = valid and ta.crossover(close, buffered_gvn_i1_buy_entry_price) and perfectEntryConf and not tradeActive_i1
slCondition_i1 = tradeActive_i1 and ta.crossunder(close, buffered_sl_i1_long_exit_price)
targetCondition_i1 = tradeActive_i1 and ta.crossover(close, dynTarget_i1 + exitBuffer)

buyCondition_i2 = valid and ta.crossover(close, buffered_gvn_i2_buy_entry_price) and perfectEntryConf and not tradeActive_i2
slCondition_i2 = tradeActive_i2 and ta.crossunder(close, buffered_sl_i2_long_exit_price)
targetCondition_i2 = tradeActive_i2 and ta.crossover(close, buffered_t_i2_long_exit_price)

buyCondition_i3 = valid and ta.crossover(close, buffered_gvn_i3_buy_entry_price) and perfectEntryConf and not tradeActive_i3
slCondition_i3 = tradeActive_i3 and ta.crossunder(close, buffered_sl_i3_long_exit_price)
targetCondition_i3 = tradeActive_i3 and ta.crossover(close, gvn_i2 + exitBuffer)

buyCondition_i5 = valid and ta.crossover(close, buffered_gvn_i5_buy_entry_price) and perfectEntryConf and not tradeActive_i5
slCondition_i5 = tradeActive_i5 and ta.crossunder(close, buffered_sl_i5_long_exit_price)
targetCondition_i5 = tradeActive_i5 and ta.crossover(close, dynTarget_i5 + exitBuffer)

buyCondition_i6 = valid and ta.crossover(close, buffered_gvn_i6_buy_entry_price) and perfectEntryConf and not tradeActive_i6
slCondition_i6 = tradeActive_i6 and ta.crossunder(close, buffered_sl_i6_long_exit_price)
targetCondition_i6 = tradeActive_i6 and ta.crossover(close, gvn_i5 + exitBuffer)

buyCondition_i7 = valid and ta.crossover(close, buffered_gvn_i7_buy_entry_price) and perfectEntryConf and not tradeActive_i7
slCondition_i7 = tradeActive_i7 and ta.crossunder(close, buffered_sl_i7_long_exit_price)
targetCondition_i7 = tradeActive_i7 and ta.crossover(close, dynTarget_i7 + exitBuffer)

// --- Unified Exact Alerts ---

// i0
if buyCondition_i0
    tradeActive_i0 := true
    msg = '{ "secret": "' + gvn_secret + '", "symbol": "' + syminfo.ticker + '", "quantity": "' + str.tostring(finalQty) + '", "orderType": "MARKET", "price": "' + str.tostring(close) + '", "transactionType": "BUY", "productType": "MARGIN", "eventType": "BUY_ACTIVE", "message": "Buy @i0" }'
    alert(msg, alert.freq_once_per_bar_close)
if slCondition_i0
    tradeActive_i0 := false
    msg = '{ "secret": "' + gvn_secret + '", "symbol": "' + syminfo.ticker + '", "quantity": "' + str.tostring(finalQty) + '", "orderType": "MARKET", "price": "' + str.tostring(close) + '", "transactionType": "SELL", "productType": "MARGIN", "status": "Closed SL" }'
    alert(msg, alert.freq_once_per_bar_close)
if targetCondition_i0
    tradeActive_i0 := false
    msg = '{ "secret": "' + gvn_secret + '", "symbol": "' + syminfo.ticker + '", "quantity": "' + str.tostring(finalQty) + '", "orderType": "MARKET", "price": "' + str.tostring(close) + '", "transactionType": "SELL", "productType": "MARGIN", "status": "Closed Target" }'
    alert(msg, alert.freq_once_per_bar)

// i1
if buyCondition_i1
    tradeActive_i1 := true
    msg = '{ "secret": "' + gvn_secret + '", "symbol": "' + syminfo.ticker + '", "quantity": "' + str.tostring(finalQty) + '", "orderType": "MARKET", "price": "' + str.tostring(math.round(close,2)) + '", "transactionType": "BUY", "productType": "MARGIN", "eventType": "BUY_ACTIVE", "message": "Buy @i1", "target": "' + str.tostring(math.round(dynTarget_i1,2)) + '", "sl": "' + str.tostring(math.round(sl_i1,2)) + '" }'
    alert(msg, alert.freq_once_per_bar)
if slCondition_i1
    tradeActive_i1 := false
    msg = '{ "secret": "' + gvn_secret + '", "symbol": "' + syminfo.ticker + '", "quantity": "' + str.tostring(finalQty) + '", "orderType": "MARKET", "price": "' + str.tostring(close) + '", "transactionType": "SELL", "productType": "MARGIN", "status": "Closed SL" }'
    alert(msg, alert.freq_once_per_bar)
if targetCondition_i1
    tradeActive_i1 := false
    msg = '{ "secret": "' + gvn_secret + '", "symbol": "' + syminfo.ticker + '", "quantity": "' + str.tostring(finalQty) + '", "orderType": "MARKET", "price": "' + str.tostring(close) + '", "transactionType": "SELL", "productType": "MARGIN", "status": "Closed Target" }'
    alert(msg, alert.freq_once_per_bar)

// i2
if buyCondition_i2
    tradeActive_i2 := true
    msg = '{ "secret": "' + gvn_secret + '", "symbol": "' + syminfo.ticker + '", "quantity": "' + str.tostring(finalQty) + '", "orderType": "MARKET", "price": "' + str.tostring(math.round(close,2)) + '", "transactionType": "BUY", "productType": "MARGIN", "eventType": "BUY_ACTIVE", "message": "Buy @i2", "target": "' + str.tostring(math.round(t_i2,2)) + '", "sl": "' + str.tostring(math.round(sl_i2,2)) + '" }'
    alert(msg, alert.freq_once_per_bar)
if slCondition_i2
    tradeActive_i2 := false
    msg = '{ "secret": "' + gvn_secret + '", "symbol": "' + syminfo.ticker + '", "quantity": "' + str.tostring(finalQty) + '", "orderType": "MARKET", "price": "' + str.tostring(close) + '", "transactionType": "SELL", "productType": "MARGIN", "status": "Closed SL" }'
    alert(msg, alert.freq_once_per_bar)
if targetCondition_i2
    tradeActive_i2 := false
    msg = '{ "secret": "' + gvn_secret + '", "symbol": "' + syminfo.ticker + '", "quantity": "' + str.tostring(finalQty) + '", "orderType": "MARKET", "price": "' + str.tostring(close) + '", "transactionType": "SELL", "productType": "MARGIN", "status": "Closed Target" }'
    alert(msg, alert.freq_once_per_bar)

// i3
if buyCondition_i3
    tradeActive_i3 := true
    msg = '{ "secret": "' + gvn_secret + '", "symbol": "' + syminfo.ticker + '", "quantity": "' + str.tostring(finalQty) + '", "orderType": "MARKET", "price": "' + str.tostring(math.round(close,2)) + '", "transactionType": "BUY", "productType": "MARGIN", "eventType": "BUY_ACTIVE", "message": "Buy @i3", "target": "' + str.tostring(math.round(gvn_i2,2)) + '", "sl": "' + str.tostring(math.round(sl_i3,2)) + '" }'
    alert(msg, alert.freq_once_per_bar)
if slCondition_i3
    tradeActive_i3 := false
    msg = '{ "secret": "' + gvn_secret + '", "symbol": "' + syminfo.ticker + '", "quantity": "' + str.tostring(finalQty) + '", "orderType": "MARKET", "price": "' + str.tostring(close) + '", "transactionType": "SELL", "productType": "MARGIN", "status": "Closed SL" }'
    alert(msg, alert.freq_once_per_bar)
if targetCondition_i3
    tradeActive_i3 := false
    msg = '{ "secret": "' + gvn_secret + '", "symbol": "' + syminfo.ticker + '", "quantity": "' + str.tostring(finalQty) + '", "orderType": "MARKET", "price": "' + str.tostring(close) + '", "transactionType": "SELL", "productType": "MARGIN", "status": "Closed Target" }'
    alert(msg, alert.freq_once_per_bar)

// i5
if buyCondition_i5
    tradeActive_i5 := true
    msg = '{ "secret": "' + gvn_secret + '", "symbol": "' + syminfo.ticker + '", "quantity": "' + str.tostring(finalQty) + '", "orderType": "MARKET", "price": "' + str.tostring(math.round(close,2)) + '", "transactionType": "BUY", "productType": "MARGIN", "eventType": "BUY_ACTIVE", "message": "Buy @i5", "target": "' + str.tostring(math.round(dynTarget_i5,2)) + '", "sl": "' + str.tostring(math.round(sl_i5,2)) + '" }'
    alert(msg, alert.freq_once_per_bar)
if slCondition_i5
    tradeActive_i5 := false
    msg = '{ "secret": "' + gvn_secret + '", "symbol": "' + syminfo.ticker + '", "quantity": "' + str.tostring(finalQty) + '", "orderType": "MARKET", "price": "' + str.tostring(close) + '", "transactionType": "SELL", "productType": "MARGIN", "status": "Closed SL" }'
    alert(msg, alert.freq_once_per_bar)
if targetCondition_i5
    tradeActive_i5 := false
    msg = '{ "secret": "' + gvn_secret + '", "symbol": "' + syminfo.ticker + '", "quantity": "' + str.tostring(finalQty) + '", "orderType": "MARKET", "price": "' + str.tostring(close) + '", "transactionType": "SELL", "productType": "MARGIN", "status": "Closed Target" }'
    alert(msg, alert.freq_once_per_bar)

// i6
if buyCondition_i6
    tradeActive_i6 := true
    msg = '{ "secret": "' + gvn_secret + '", "symbol": "' + syminfo.ticker + '", "quantity": "' + str.tostring(finalQty) + '", "orderType": "MARKET", "price": "' + str.tostring(math.round(close,2)) + '", "transactionType": "BUY", "productType": "MARGIN", "eventType": "BUY_ACTIVE", "message": "Buy @i6", "target": "' + str.tostring(math.round(gvn_i5,2)) + '", "sl": "' + str.tostring(math.round(sl_i6,2)) + '" }'
    alert(msg, alert.freq_once_per_bar)
if slCondition_i6
    tradeActive_i6 := false
    msg = '{ "secret": "' + gvn_secret + '", "symbol": "' + syminfo.ticker + '", "quantity": "' + str.tostring(finalQty) + '", "orderType": "MARKET", "price": "' + str.tostring(close) + '", "transactionType": "SELL", "productType": "MARGIN", "status": "Closed SL" }'
    alert(msg, alert.freq_once_per_bar)
if targetCondition_i6
    tradeActive_i6 := false
    msg = '{ "secret": "' + gvn_secret + '", "symbol": "' + syminfo.ticker + '", "quantity": "' + str.tostring(finalQty) + '", "orderType": "MARKET", "price": "' + str.tostring(close) + '", "transactionType": "SELL", "productType": "MARGIN", "status": "Closed Target" }'
    alert(msg, alert.freq_once_per_bar)

// i7
if buyCondition_i7
    tradeActive_i7 := true
    msg = '{ "secret": "' + gvn_secret + '", "symbol": "' + syminfo.ticker + '", "quantity": "' + str.tostring(finalQty) + '", "orderType": "MARKET", "price": "' + str.tostring(math.round(close,2)) + '", "transactionType": "BUY", "productType": "MARGIN", "eventType": "BUY_ACTIVE", "message": "Buy @i7", "target": "' + str.tostring(math.round(dynTarget_i7,2)) + '", "sl": "' + str.tostring(math.round(sl_i7,2)) + '" }'
    alert(msg, alert.freq_once_per_bar)
if slCondition_i7
    tradeActive_i7 := false
    msg = '{ "secret": "' + gvn_secret + '", "symbol": "' + syminfo.ticker + '", "quantity": "' + str.tostring(finalQty) + '", "orderType": "MARKET", "price": "' + str.tostring(close) + '", "transactionType": "SELL", "productType": "MARGIN", "status": "Closed SL" }'
    alert(msg, alert.freq_once_per_bar)
if targetCondition_i7
    tradeActive_i7 := false
    msg = '{ "secret": "' + gvn_secret + '", "symbol": "' + syminfo.ticker + '", "quantity": "' + str.tostring(finalQty) + '", "orderType": "MARKET", "price": "' + str.tostring(close) + '", "transactionType": "SELL", "productType": "MARGIN", "status": "Closed Target" }'
    alert(msg, alert.freq_once_per_bar)
